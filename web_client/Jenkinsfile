pipeline {
    agent any

    environment {
        IMAGE_NAME = "efforthye/richclub-front"
        CONTAINER_NAME = "richclub-front"
        APP_PORT = "3000"
        HOST_IP = "192.168.219.100"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Docker Image') {
            steps {
                sh "docker build --build-arg NODE_OPTIONS=--max_old_space_size=512 -t ${IMAGE_NAME}:${BUILD_NUMBER} ./web_client"
                sh "docker tag ${IMAGE_NAME}:${BUILD_NUMBER} ${IMAGE_NAME}:latest"
            }
        }

        stage('Push to DockerHub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-credentials',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh "echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin"
                    sh "docker push ${IMAGE_NAME}:${BUILD_NUMBER}"
                    sh "docker push ${IMAGE_NAME}:latest"
                }
            }
        }

        stage('Deploy') {
            steps {
                sh """
                    docker stop ${CONTAINER_NAME} || true
                    docker rm ${CONTAINER_NAME} || true
                    docker run -d \\
                        --name ${CONTAINER_NAME} \\
                        --restart unless-stopped \\
                        -p ${APP_PORT}:80 \\
                        ${IMAGE_NAME}:latest
                """
            }
        }

        stage('Health Check') {
            steps {
                sh "sleep 5"
                sh "curl -f http://${HOST_IP}:${APP_PORT} || exit 1"
            }
        }
    }

    post {
        success {
            echo "프론트 배포 성공: ${IMAGE_NAME}:${BUILD_NUMBER}"
        }
        failure {
            echo "프론트 배포 실패"
            sh "docker stop ${CONTAINER_NAME} || true"
        }
        always {
            sh "docker image prune -f"
        }
    }
}
